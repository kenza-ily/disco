# ========================================
# DISCO - Document Intelligence Suite
# ========================================
# Copy this file to .env.local and fill in your credentials.
# You only need credentials for the providers you want to use.

# ========================================
# Option 1: Azure OpenAI + Document Intelligence
# ========================================
# Get credits: https://azure.microsoft.com/free/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_API_VERSION=2024-02-01
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key-here

# ========================================
# Option 2: Anthropic Direct API
# ========================================
# Get key: https://console.anthropic.com/
# Recommended for Claude models (simpler than AWS Bedrock)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ========================================
# Option 3: AWS Bedrock (for Claude)
# ========================================
# Alternative to direct Anthropic API
# Requires AWS account with Bedrock access
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
# OR use AWS profile (leave above empty)
AWS_PROFILE=default

# ========================================
# Option 4: Mistral OCR
# ========================================
# Get key: https://console.mistral.ai/
MISTRAL_API_KEY=your-key-here

# ========================================
# HuggingFace (Required for datasets)
# ========================================
# Login required to access datasets under kenza-ily/ org
# Run: huggingface-cli login
# Or set token here:
# HF_TOKEN=hf_your_token_here
